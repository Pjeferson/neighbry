# frozen_string_literal: true

source "https://rubygems.org"

gem "rails", "~> 8.1.3"
gem "pg", "~> 1.1"
gem "puma", ">= 5.0"

# State machine — PaymentOrder
gem "aasm"

# Service objects
gem "dry-monads"

# Políticas de acesso
gem "pundit"

# Serializers
gem "jsonapi-serializer"

# RabbitMQ
gem "bunny"
gem "sneakers"

# Redis — idempotência via Idempotency-Key
gem "redis"

# HTTP client — chamadas ao account-service e spb-mock
gem "faraday"

# JWT verification (sem Devise — apenas verifica tokens emitidos pelo account-service)
gem "jwt"

# CORS
gem "rack-cors"

# Jobs assíncronos e cron (ExpirePendingApprovalsJob)
gem "solid_queue"

# Infraestrutura Rails
gem "bootsnap", require: false
gem "tzinfo-data", platforms: %i[windows jruby]

