<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; color: #333;">
  <div style="background: #1a1a2e; padding: 24px; border-radius: 8px 8px 0 0;">
    <h1 style="color: #fff; margin: 0; font-size: 20px;">CredFlow — Aprovação Necessária</h1>
  </div>

  <div style="background: #f9f9f9; padding: 24px; border: 1px solid #e0e0e0;">
    <p>Uma ordem de pagamento requer sua aprovação.</p>

    <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
      <tr style="border-bottom: 1px solid #e0e0e0;">
        <td style="padding: 8px 0; font-weight: bold; width: 40%;">Valor</td>
        <td style="padding: 8px 0;"><%= @amount_reais %></td>
      </tr>
      <tr style="border-bottom: 1px solid #e0e0e0;">
        <td style="padding: 8px 0; font-weight: bold;">Beneficiário</td>
        <td style="padding: 8px 0;"><%= @beneficiary_doc %></td>
      </tr>
      <tr style="border-bottom: 1px solid #e0e0e0;">
        <td style="padding: 8px 0; font-weight: bold;">Motivo</td>
        <td style="padding: 8px 0;"><%= @reason %></td>
      </tr>
      <tr style="border-bottom: 1px solid #e0e0e0;">
        <td style="padding: 8px 0; font-weight: bold;">Aprovações</td>
        <td style="padding: 8px 0;"><%= @approvals_received %> de <%= @approvers_needed %> recebidas</td>
      </tr>
      <tr>
        <td style="padding: 8px 0; font-weight: bold;">Expira em</td>
        <td style="padding: 8px 0;"><%= @expires_at %></td>
      </tr>
    </table>

    <div style="text-align: center; margin-top: 24px;">
      <a href="<%= @approval_link %>"
         style="background: #4f46e5; color: #fff; padding: 12px 32px; text-decoration: none;
                border-radius: 6px; font-weight: bold; display: inline-block;">
        Revisar e Aprovar
      </a>
    </div>

    <p style="font-size: 12px; color: #888; margin-top: 24px;">
      ID da ordem: <%= @payment_order_id %><br>
      Conta: <%= @account_id %>
    </p>
  </div>
</div>
